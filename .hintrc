{
  "extends": [
    "development"
  ],
  "hints": {
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "border: 1px solid color-mix(in srgb, var(--purple-lt) 50%, transparent)",
          "backdrop-filter",
          "user-select",
          "border: 1px solid color-mix(in srgb, var(--purple-lt) 40%, transparent)",
          "-webkit-overflow-scrolling",
          "border: 1px solid color-mix(in srgb, var(--purple-lt) 18%, transparent)",
          "border-color: color-mix(in srgb, var(--purple-lt) 60%, transparent)",
          "min-height: auto",
          "border-color: color-mix(in srgb, var(--accent) 30%, transparent)",
          "border-color: color-mix(in srgb, var(--purple-lt) 40%, transparent)"
        ]
      }
    ]
  }
}